---
// src/components/Socials.astro

import { SOCIALS } from "@consts";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;

const iconClass =
  "size-8 transition-transform duration-300 group-hover:scale-110";

const buttonClass =
  "group flex size-16 items-center justify-center rounded-full border-[3px] border-black/60 bg-transparent text-black/75 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:scale-105 hover:border-black hover:bg-black hover:text-white hover:shadow-lg dark:border-white/60 dark:text-white/80 dark:hover:border-white dark:hover:bg-white dark:hover:text-black";
---

<ul class:list={["flex items-center gap-3", className]}>
  {SOCIALS.map((social) => {
    const name = social.NAME.toLowerCase();
    const isEmail = name === "email" || name === "mail" || social.HREF.startsWith("mailto:");
    const emailAddress = social.HREF.replace("mailto:", "");

    if (isEmail) {
      return (
        <li class="relative">
          <button
            type="button"
            data-email-button
            aria-expanded="false"
            aria-label={`Show email options for ${emailAddress}`}
            class={buttonClass}
          >
            <svg
              class={iconClass}
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="M3 7l9 6 9-6" />
            </svg>
          </button>

          <div
            data-email-menu
            class="absolute left-1/2 top-full z-50 mt-3 hidden w-64 -translate-x-1/2 rounded-2xl border border-black/15 bg-stone-100 p-4 text-left text-sm shadow-xl dark:border-white/15 dark:bg-stone-900"
          >
            <p class="break-all font-medium text-black dark:text-white">
              {emailAddress}
            </p>

            <div class="mt-3 flex gap-2">
              <a
                href={social.HREF}
                class="rounded-full border border-black/20 px-3 py-1.5 text-black transition-colors duration-300 hover:bg-black hover:text-white dark:border-white/20 dark:text-white dark:hover:bg-white dark:hover:text-black"
              >
                Mail
              </a>

              <button
                type="button"
                data-copy-email={emailAddress}
                class="rounded-full border border-black/20 px-3 py-1.5 text-black transition-colors duration-300 hover:bg-black hover:text-white dark:border-white/20 dark:text-white dark:hover:bg-white dark:hover:text-black"
              >
                Copy
              </button>
            </div>
          </div>
        </li>
      );
    }

    return (
      <li>
        <a
          href={social.HREF}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={social.NAME}
          class={buttonClass}
        >
          {name === "github" && (
            <svg
              class={iconClass}
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.93.58.11.79-.25.79-.56v-2.02c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.33.96.1-.74.4-1.25.73-1.54-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.16 1.18A10.9 10.9 0 0 1 12 6.13c.98 0 1.96.13 2.88.39 2.19-1.49 3.15-1.18 3.15-1.18.63 1.59.24 2.77.12 3.06.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.69.41.35.78 1.05.78 2.12v3.15c0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
              />
            </svg>
          )}

          {name === "linkedin" && (
            <svg
              class={iconClass}
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.32 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.1 20.45H3.54V9H7.1v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0Z" />
            </svg>
          )}

          {(name === "x" || name === "twitter") && (
            <svg
              class={iconClass}
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932L18.901 1.153Zm-1.293 19.492h2.039L6.486 3.24H4.298l13.31 17.405Z" />
            </svg>
          )}

          {!["github", "linkedin", "x", "twitter"].includes(name) && (
            <span class="text-sm">{social.NAME}</span>
          )}
        </a>
      </li>
    );
  })}
</ul>

<script>
  function closeEmailMenus() {
    document.querySelectorAll("[data-email-menu]").forEach((menu) => {
      menu.classList.add("hidden");
    });

    document.querySelectorAll("[data-email-button]").forEach((button) => {
      button.setAttribute("aria-expanded", "false");
    });
  }

  document.addEventListener("click", async (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    const copyButton = target.closest("[data-copy-email]");
    if (copyButton) {
      const email = copyButton.getAttribute("data-copy-email");

      if (email) {
        await navigator.clipboard.writeText(email);

        const originalText = copyButton.textContent;
        copyButton.textContent = "Copied";

        setTimeout(() => {
          copyButton.textContent = originalText;
        }, 1200);
      }

      return;
    }

    const emailButton = target.closest("[data-email-button]");
    if (emailButton) {
      const listItem = emailButton.closest("li");
      const menu = listItem?.querySelector("[data-email-menu]");

      if (!menu) {
        return;
      }

      const wasHidden = menu.classList.contains("hidden");

      closeEmailMenus();

      if (wasHidden) {
        menu.classList.remove("hidden");
        emailButton.setAttribute("aria-expanded", "true");
      }

      return;
    }

    if (!target.closest("[data-email-menu]")) {
      closeEmailMenus();
    }
  });
</script>